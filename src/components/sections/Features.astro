---
const features = [
  {
    title: "Auto Reply to DMs",
    description: "Instantly reply to every direct message with personalized, context-aware responses and flows.",
    icon: `<svg class="w-10 h-10 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" /></svg>`
  },
  {
    title: "Comment to DM Automation",
    description: "Automatically slide into DMs when someone comments on your posts or reels to boost engagement.",
    icon: `<svg class="w-10 h-10 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z" /></svg>`
  },
  {
    title: "Lead Capture from Instagram",
    description: "Qualify leads automatically and collect contact info directly inside the Instagram conversation.",
    icon: `<svg class="w-10 h-10 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" /></svg>`
  },
  {
    title: "WhatsApp Chatbot",
    description: "Deploy powerful automated assistants on WhatsApp to handle support and sales 24/7.",
    icon: `<svg class="w-10 h-10 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>`
  },
  {
    title: "Send Product Catalogs",
    description: "Display and send your entire product collection within WhatsApp and Instagram dynamically.",
    icon: `<svg class="w-10 h-10 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" /></svg>`
  },
  {
    title: "Automated Bookings",
    description: "Let customers book appointments and schedule demos directly through your chat interfaces.",
    icon: `<svg class="w-10 h-10 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>`
  }
];
---
<section id="features" class="py-24 bg-gray-50/50">
  <div class="px-4 mx-auto max-w-7xl sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl font-extrabold text-gray-900 sm:text-4xl md:text-5xl">
        Everything you need to automate your social sales
      </h2>
      <p class="mt-4 text-lg text-gray-600">
        Powerful features designed to help you sell more and work less on Instagram and WhatsApp.
      </p>
    </div>
    
    <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
      {features.map((feature) => (
        <div class="p-8 bg-white border border-gray-100 rounded-2xl shadow-sm hover:shadow-md transition-all duration-300 group">
          <div class="mb-6 p-4 bg-indigo-50 rounded-xl inline-block group-hover:bg-indigo-600 transition-colors duration-300">
            <Fragment set:html={feature.icon.replace('text-indigo-600', 'text-indigo-600 group-hover:text-white')} />
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">{feature.title}</h3>
          <p class="text-gray-600 leading-relaxed">
            {feature.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
