---
---
<section class="py-24 bg-gray-50">
  <div class="px-4 mx-auto max-w-7xl sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl font-extrabold text-gray-900 sm:text-4xl">See Automation in Action</h2>
      <p class="mt-4 text-xl text-gray-500">Watch how a simple comment turns into a sales opportunity.</p>
    </div>
    
    <div class="relative max-w-4xl mx-auto">
      <div class="aspect-video bg-gray-900 rounded-3xl shadow-2xl overflow-hidden border border-gray-800 flex items-center justify-center group cursor-pointer">
        <div class="absolute inset-0 opacity-40 bg-[url('https://images.unsplash.com/photo-1611162617213-7d7a39e9b1d7?w=1000&auto=format&fit=crop&q=60')] bg-cover bg-center"></div>
        <div class="relative w-20 h-20 bg-indigo-600 rounded-full flex items-center justify-center shadow-xl group-hover:scale-110 transition-transform duration-300">
          <svg class="w-8 h-8 text-white ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z" /></svg>
        </div>
      </div>
      
      {/* Floating UI cards */}
      <div class="hidden lg:block absolute -right-12 -bottom-8 w-64 bg-white p-4 rounded-2xl shadow-xl border border-gray-100 animate-bounce-slow">
         <div class="flex items-center gap-3 mb-3">
           <div class="w-8 h-8 rounded-lg bg-indigo-100 flex items-center justify-center text-indigo-600">
             <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
           </div>
           <p class="text-xs font-bold text-gray-900">Automation Triggered</p>
         </div>
         <p class="text-[10px] text-gray-500 leading-relaxed">User "modern_shop" just commented "Price?" on your latest reel.</p>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes bounce-slow {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
  .animate-bounce-slow {
    animation: bounce-slow 4s ease-in-out infinite;
  }
</style>
