<section class="py-24">
  <div class="px-4 mx-auto max-w-7xl sm:px-6 lg:px-8">
    <div class="relative px-8 py-16 overflow-hidden bg-indigo-600 rounded-3xl sm:px-16 md:py-24 text-center">
      <div class="absolute inset-0 opacity-10 bg-[radial-gradient(circle_at_50%_50%,rgba(255,255,255,1),transparent)]"></div>
      <div class="relative z-10">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl md:text-5xl lg:text-6xl mb-8">
          Start Automating Your <br class="hidden sm:block" /> Instagram Today
        </h2>
        <p class="max-w-2xl mx-auto mb-10 text-xl text-indigo-100 italic">
          "The best way to grow your business while you sleep."
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="#" class="w-full sm:w-auto inline-flex items-center justify-center px-10 py-5 text-lg font-bold text-indigo-600 transition-all duration-200 bg-white rounded-2xl hover:bg-gray-50 shadow-xl">
            Start Free Trial
          </a>
          <p class="text-indigo-200 text-sm font-medium">No credit card required.</p>
        </div>
      </div>
      
      {/* Decorative Orbs */}
      <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/2 w-64 h-64 bg-white/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/2 w-64 h-64 bg-orange-400/20 rounded-full blur-3xl"></div>
    </div>
  </div>
</section>
