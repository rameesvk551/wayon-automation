---
const capabilities = [
  { title: "Comment → DM", icon: "💬" },
  { title: "Keyword Trigger", icon: "🔑" },
  { title: "Auto Reply", icon: "🤖" },
  { title: "Broadcast", icon: "📢" },
  { title: "Product Catalog", icon: "🛍️" },
  { title: "WhatsApp Automation", icon: "📱" }
];
---
<section class="py-24 bg-white">
  <div class="px-4 mx-auto max-w-7xl sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl font-extrabold text-gray-900 mb-4">Powerful Automation Capabilities</h2>
      <p class="text-gray-500">Scale your communication across every touchpoint.</p>
    </div>
    
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6">
      {capabilities.map((item) => (
        <div class="flex flex-col items-center p-6 bg-white border border-gray-100 rounded-2xl hover:border-indigo-600 hover:shadow-lg hover:shadow-indigo-50 transition-all duration-300">
          <div class="text-4xl mb-4 grayscale group-hover:grayscale-0 transition-all">{item.icon}</div>
          <h3 class="text-sm font-bold text-gray-900 text-center">{item.title}</h3>
        </div>
      ))}
    </div>
  </div>
</section>
