---
---
<section class="py-24 bg-gray-50 overflow-hidden">
  <div class="px-4 mx-auto max-w-7xl sm:px-6 lg:px-8">
    <div class="grid items-center grid-cols-1 gap-16 lg:grid-cols-2">
      <div class="order-2 lg:order-1">
        <div class="inline-flex items-center px-4 py-1.5 rounded-full bg-orange-50 border border-orange-100 mb-6">
          <span class="text-xs font-semibold tracking-widest text-orange-600 uppercase">Conversion Engine</span>
        </div>
        <h2 class="text-3xl font-extrabold text-gray-900 sm:text-4xl md:text-5xl mb-6">
          Capture Leads Automatically
        </h2>
        <p class="text-xl text-gray-600 leading-relaxed mb-8">
          Turn passive followers into qualified leads. Our chatbot conversational flows are designed to capture contact information and qualify prospects before they even leave the chat.
        </p>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {[
            { title: "Collect Emails", desc: "Sync directly to your CRM or email list." },
            { title: "Phone Numbers", desc: "For SMS marketing and direct sales calls." },
            { title: "Book Appointments", desc: "Integrated booking for demos and calls." },
            { title: "Qualify Leads", desc: "Filter prospects based on their answers." }
          ].map((item) => (
            <div class="flex flex-col gap-2">
              <h3 class="font-bold text-gray-900">{item.title}</h3>
              <p class="text-sm text-gray-500">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
      
      <div class="relative order-1 lg:order-2 group">
        <div class="absolute -inset-4 bg-orange-100/50 rounded-3xl blur-2xl group-hover:bg-orange-200/50 transition-colors duration-500"></div>
        <div class="relative bg-white border border-gray-100 rounded-3xl shadow-xl overflow-hidden p-8">
          <div class="bg-indigo-50 rounded-2xl p-6 border border-indigo-100">
            <p class="text-sm font-bold text-indigo-700 mb-4">Lead Qualification Flow</p>
            <div class="space-y-4">
              <div class="w-full bg-white rounded-xl p-3 border border-indigo-100 text-sm text-gray-600">
                Hi! What's your business email?
              </div>
              <div class="w-full bg-indigo-600 rounded-xl p-3 text-sm text-white text-right">
                hello@example.com
              </div>
              <div class="w-full bg-white rounded-xl p-3 border border-indigo-100 text-sm text-gray-600">
                Got it! And what is your monthly revenue?
              </div>
              <div class="grid grid-cols-2 gap-2 mt-4">
                <button class="bg-indigo-50 border border-indigo-200 text-indigo-700 py-2 rounded-lg text-xs font-bold">$0 - $10k</button>
                <button class="bg-indigo-50 border border-indigo-200 text-indigo-700 py-2 rounded-lg text-xs font-bold">$10k - $50k</button>
                <button class="bg-indigo-600 text-white py-2 rounded-lg text-xs font-bold shadow-md shadow-indigo-100">$50k - $200k</button>
                <button class="bg-indigo-50 border border-indigo-200 text-indigo-700 py-2 rounded-lg text-xs font-bold">$200k+</button>
              </div>
            </div>
          </div>
          
          <div class="mt-6 flex items-center justify-between px-4 py-3 bg-green-50 rounded-xl border border-green-100">
             <div class="flex items-center gap-2">
               <div class="w-8 h-8 rounded-full bg-green-500 flex items-center justify-center text-white">
                 <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
               </div>
               <p class="text-xs font-bold text-green-700">Lead Qualified & Saved to CRM</p>
             </div>
             <p class="text-[10px] font-bold text-green-600/50">JUST NOW</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
